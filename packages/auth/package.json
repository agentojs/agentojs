{
  "name": "@agentojs/auth",
  "version": "0.3.0",
  "description": "Lightweight API key utilities for AgentOJS — generate, hash, validate, and middleware",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agentojs/agentojs",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/agentojs/agentojs/issues"
  },
  "homepage": "https://github.com/agentojs/agentojs/tree/main/packages/auth#readme",
  "keywords": [
    "api-key",
    "auth",
    "authentication",
    "middleware",
    "ai",
    "agent",
    "commerce",
    "agentic middleware"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "author": "AgentOJS Contributors",
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@agentojs/generic",
  "version": "0.1.0",
  "description": "Connect any REST API store to AI agents (Claude, ChatGPT, Gemini) — universal adapter with field mapping",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/agentojs/agentojs",
    "directory": "packages/generic"
  },
  "homepage": "https://agentojs.com",
  "keywords": ["mcp", "ucp", "acp", "rest-api", "generic-adapter", "field-mapping", "ai-agent", "ai-commerce", "agentic-middleware", "claude", "chatgpt", "gemini", "any-backend", "custom-store", "model-context-protocol"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@agentojs/core": "^0.1.0"
  },
  "devDependencies": {
    "@agentojs/core": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

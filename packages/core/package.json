{
  "name": "@agentojs/core",
  "version": "0.1.0",
  "description": "Agentic middleware for AI commerce — connect any store to Claude (MCP), ChatGPT (ACP), and Gemini (UCP)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/agentojs/agentojs",
    "directory": "packages/core"
  },
  "homepage": "https://agentojs.com",
  "keywords": ["mcp", "ucp", "acp", "ai-agent", "ai-commerce", "agentic-middleware", "claude", "chatgpt", "gemini", "e-commerce", "commerce-backend", "model-context-protocol", "unified-commerce-protocol", "agent-commerce-protocol", "open-source"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
